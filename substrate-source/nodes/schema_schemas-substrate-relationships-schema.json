)?$\"\n          },\n          \"evidence\": {\r\n            \"type\": \"array\",\r\n            \"items\": { \"type\": \"string\" }\r\n          },\r\n          \"external\": { \"type\": \"boolean\" },\r\n          \"target_substrate\": { \"type\": \"string\" }\r\n        }\r\n      }\r\n    }\r\n  }\r\n}\r\n",
