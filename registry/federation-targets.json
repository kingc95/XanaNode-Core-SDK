{
  "$schema": "./federation-targets.schema.json",
  "federation_targets": [
    {
      "id": "xananode.canonical",
      "name": "XanaNode Canonical Pack",
      "namespace": "xananode.canonical",
      "description": "The canonical XanaNode substrate pack for protocol vocabulary, project identity, governance, software stack records, and self-referential examples.",
      "status": "canonical",
      "repository": {
        "type": "git",
        "url": "https://github.com/kingc95/XanaNode-Core-SDK.git",
        "default_branch": "main",
        "substrate_path": "packs/xananode-canonical"
      },
      "recommended_mode": "mounted",
      "licenses": ["CC-BY-4.0", "Apache-2.0"],
      "homepage": "https://xananode.com/"
    },
    {
      "id": "xananode.lineage",
      "name": "XanaNode Lost Lineage Pack",
      "namespace": "xananode.lineage",
      "description": "A lineage substrate for the historical and conceptual path into XanaNode.",
      "status": "community",
      "repository": {
        "type": "git",
        "url": "https://github.com/kingc95/XanaNode-Core-SDK.git",
        "default_branch": "main",
        "substrate_path": "packs/xananode-lineage"
      },
      "recommended_mode": "mounted",
      "licenses": ["CC-BY-4.0"],
      "homepage": "https://xananode.com/"
    }
  ]
}
